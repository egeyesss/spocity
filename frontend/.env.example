# Copy this file to .env.local and fill in your values.

# Spotify OAuth (from https://developer.spotify.com/dashboard)
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=

# Backend URL for server-side rendering (runs inside Docker, uses internal DNS)
API_URL=http://backend:8000

# Backend URL for browser requests (must be reachable from the user's machine)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
